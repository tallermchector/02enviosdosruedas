# AI Exclusion File - Evita el consumo innecesario de tokens y protege secretos
# Excluye directorios de dependencias y compilación
node_modules/
.next/
dist/
build/
out/
.hermes/
.git/

# Excluye archivos de bloqueo de paquetes pesados (muy ruidosos en contexto)
pnpm-lock.yaml
package-lock.json
yarn.lock

# Excluye variables de entorno por seguridad y privacidad
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Excluye carpetas de caché y logs de sistemas
.npm/
.eslintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.turbo/

# Excluye archivos temporales de editores
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Excluye archivos binarios de imagen pesados en public/ que no requieren análisis de código
public/**/*.png
public/**/*.jpg
public/**/*.jpeg
public/**/*.webp
public/**/*.gif
public/**/*.ico
public/**/*.svg
